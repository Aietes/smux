{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Aietes/smux/main/schemas/smux-config.schema.json",
  "title": "smux config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "settings": {
      "$ref": "#/$defs/settings"
    }
  },
  "$defs": {
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_template": {
          "type": "string",
          "description": "Template name used when no CLI or project override applies."
        },
        "icons": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ],
          "default": "auto",
          "description": "Controls picker icon rendering."
        },
        "icon_colors": {
          "$ref": "#/$defs/icon_colors"
        },
        "picker": {
          "$ref": "#/$defs/picker"
        },
        "folder_search": {
          "$ref": "#/$defs/folder_search"
        }
      }
    },
    "folder_search": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [
            "~"
          ],
          "description": "Directory roots scanned by smux select in addition to zoxide."
        },
        "max_depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 16,
          "default": 3,
          "description": "Maximum folder-search depth below each root."
        },
        "include_hidden": {
          "type": "boolean",
          "default": false,
          "description": "Whether folder search descends into hidden directories."
        }
      }
    },
    "picker": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bindings": {
          "$ref": "#/$defs/picker_bindings"
        },
        "preview": {
          "$ref": "#/$defs/picker_preview"
        },
        "show_hints": {
          "type": "boolean",
          "default": true,
          "description": "Whether the picker shows the keyboard-shortcut hint bar by default. It can always be toggled at runtime with the toggle_hints key."
        }
      }
    },
    "picker_bindings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reset": {
          "type": "string",
          "default": "ctrl-c",
          "description": "Main picker shortcut that resets the list back to all entries."
        },
        "sessions": {
          "type": "string",
          "default": "ctrl-s",
          "description": "Main picker shortcut that filters to tmux sessions."
        },
        "folders": {
          "type": "string",
          "default": "ctrl-f",
          "description": "Main picker shortcut that filters to folders."
        },
        "projects": {
          "type": "string",
          "default": "ctrl-p",
          "description": "Main picker shortcut that filters to saved projects."
        },
        "delete_session": {
          "type": "string",
          "default": "ctrl-x",
          "description": "Main picker shortcut that deletes the selected session or project."
        },
        "save_project": {
          "type": "string",
          "default": "alt-s",
          "description": "Main picker shortcut that saves the selected tmux session as a project."
        },
        "rename_session": {
          "type": "string",
          "default": "ctrl-r",
          "description": "Main picker shortcut that renames the selected tmux session."
        },
        "edit_project": {
          "type": "string",
          "default": "ctrl-e",
          "description": "Main picker shortcut that opens the selected project file in $EDITOR."
        },
        "toggle_hints": {
          "type": "string",
          "default": "?",
          "description": "Picker shortcut that shows or hides the keyboard-shortcut hint bar."
        }
      }
    },
    "picker_preview": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sessions": {
          "type": "string",
          "description": "Shell command used for session previews. It runs with SMUX_PREVIEW_SESSION and SMUX_PREVIEW_KIND set."
        },
        "folders": {
          "type": "string",
          "description": "Shell command used for folder previews. It runs with SMUX_PREVIEW_PATH and SMUX_PREVIEW_KIND set."
        },
        "projects": {
          "type": "string",
          "description": "Shell command used for project and broken-project previews. It runs with SMUX_PREVIEW_FILE and SMUX_PREVIEW_KIND set."
        }
      }
    },
    "icon_colors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "session": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "default": 75
        },
        "directory": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "default": 108
        },
        "template": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "default": 179
        },
        "project": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255,
          "default": 81
        }
      }
    }
  }
}
